# Arkwen — environment configuration
# Copy to `.env` for local use, or set these as service variables on Railway.
# `.env` itself is gitignored; only this example is tracked.
#
# Legend: [railway] = injected by Railway automatically · [you] = you set it

# ── Networking ───────────────────────────────────────────────────────────────
# Listen port. Railway injects it; pin it so the bind, the TCP-proxy internal
# port, and the healthcheck all agree on one number. [railway] (pin to 8080)
PORT=8080

# ── Event store ──────────────────────────────────────────────────────────────
# Postgres DSN → durable append-only event store. Absent ⇒ in-memory (non-durable).
# On Railway this comes from the Postgres plugin: DATABASE_URL=${{Postgres.DATABASE_URL}}
# [railway] (via the Postgres plugin; leave unset locally for in-memory)
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# ── Command-plane security (Invariant 7: fail-closed) ────────────────────────
# Bearer credential for the gRPC CommandPlane. UNSET on a public bind ⇒ the
# command plane is SEALED (every RPC → Unauthenticated); /healthz + status still
# serve. Set a strong secret to open commands. [you] (set a secret to open)
# ARKWEN_OPERATOR_TOKEN=change-me-to-a-strong-secret

# Acknowledge that a provisioned token crosses the PLAINTEXT TCP proxy (Railway's
# TCP proxy does not terminate TLS). REQUIRED alongside ARKWEN_OPERATOR_TOKEN on a
# public bind — the app refuses to start otherwise. [you] (set to 1 to open over plaintext)
# ARKWEN_ALLOW_INSECURE_PUBLIC=1

# Fail-fast at boot if ARKWEN_OPERATOR_TOKEN is unset (strict production). [you] optional
ARKWEN_REQUIRE_OPERATOR_TOKEN=false

# ── Runtime behaviour ────────────────────────────────────────────────────────
# Worker kind for runs that carry no `worker_kind` label. [you] optional
ARKWEN_DEFAULT_WORKER=claude-code

# Drive runs autonomously on enqueue. [you] optional
ARKWEN_AUTODRIVE=true

# ── Lifecycle ────────────────────────────────────────────────────────────────
# SIGTERM→SIGKILL grace window (Railway default 0; the app drains in ≤15s). [you] (set 25)
RAILWAY_DEPLOYMENT_DRAINING_SECONDS=25
