{
  "vector": "reproduce-determinism",
  "adr": ["ADR-001", "ADR-007 E6", "ADR-009 R1"],
  "invariants": [6, 8],
  "description": "reproduce(run_id) resolves every RunSeed field to bytes. Because identity == digest, two resolutions of the same snapshot-mode seed yield byte-identical inputs (Invariant 6). A mount-mode seed is explicitly NOT bit-reproducible and its reproduce output is classified DEGRADED — a RESULT classification, never a lifecycle or terminal STATE (Invariant 8). The seed is frozen at run.created and never re-resolved.",
  "conventions": "canonical proto3 JSON. run-A and run-B are the run.created payloads; resolvedInputs models reproduce() output (not a wire message — DEGRADED deliberately lives outside the wire enums).",
