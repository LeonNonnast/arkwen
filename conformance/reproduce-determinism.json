    "mustReject": {
      "description": "a seed field carrying a floating channel alias instead of a resolved digest",
      "badSeedFragment": {"workbenchSnapshotRef": {"algorithm": "DIGEST_ALGORITHM_SHA256", "hex": "channel:tested"}}
    }
  },
  "assertions": [
    {"id": "D1", "invariant": [6], "assert": "reproduceRunA_pass1.resolvedInputs == reproduceRunA_pass2.resolvedInputs field-by-field (identity == digest, so re-resolving the same seed yields byte-identical inputs)", "expect": "pass"},
    {"id": "D2", "invariant": [6], "assert": "runA seed.sessionSeed equals the value resolved in both reproduce passes; the strict reproduce reuses the frozen sessionSeed rather than drawing a fresh one", "expect": "pass"},
    {"id": "D3", "invariant": [6], "assert": "the mustReject seed fragment is invalid: workbenchSnapshotRef must be a resolved Digest, not a floating channel alias; ranges/channels are resolved exactly once at run.created and frozen (a channel string in a seed is rejected)", "expect": "reject"},
    {"id": "D4", "invariant": [8], "assert": "reproduceRunB.classification == 'DEGRADED' and the string 'DEGRADED' is NOT a member of lifecycleStateNames nor terminalStateNames — DEGRADED annotates the reproduce result only, never a run state", "expect": "pass"},
    {"id": "D5", "invariant": [6], "assert": "runB uses the workbench_baseline oneof branch workbenchMountRef (mutually exclusive with workbenchSnapshotRef) with materializationMode MATERIALIZATION_MODE_MOUNT — the mount branch is structurally the non-reproducible one", "expect": "pass"}
  ]
}
